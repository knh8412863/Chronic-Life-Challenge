# Copy this file to project root `.env` on the deployment host.
# Do not commit real secrets or API keys.

# docker
DOCKER_USER=ozcodingschool
DOCKER_REPOSITORY=ai-health

# fastapi
ENV=prod
APP_VERSION=v1.0.0
SECRET_KEY=change-me-production-secret
COOKIE_DOMAIN=example.com
CORS_ALLOW_ORIGINS=https://example.com
CORS_ALLOW_CREDENTIALS=true
SECURITY_CSP=default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; object-src 'none'; base-uri 'self'
HSTS_MAX_AGE_SECONDS=31536000

# ai-worker
AI_WORKER_VERSION=v1.0.0

# db
DB_HOST=mysql
DB_PORT=3306
DB_EXPOSE_PORT=3306
DB_USER=all4health
DB_PASSWORD=change-me-db-password
DB_ROOT_PASSWORD=change-me-root-password
DB_NAME=ai_health
DB_CONNECT_TIMEOUT=5
DB_CONNECTION_POOL_MAXSIZE=10

# redis
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

# jwt / auth
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_MINUTES=10080
JWT_LEEWAY=5
AUTH_RATE_LIMIT_MAX_FAILURES=5
AUTH_RATE_LIMIT_MAX_IP_FAILURES=30
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
EMAIL_VERIFICATION_EXPIRE_HOURS=24
EMAIL_VERIFICATION_COOLDOWN_SECONDS=60
PASSWORD_RESET_EXPIRE_MINUTES=30
PASSWORD_RESET_COOLDOWN_SECONDS=60

# openai llm
ADVICE_LLM_ENABLED=false
REPORT_LLM_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=10
