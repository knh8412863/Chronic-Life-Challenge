# Copy this file to project root `.env` for local uv/FastAPI runs.
# Do not commit real secrets or API keys.

# docker
DOCKER_USER=ozcodingschool
DOCKER_REPOSITORY=ai-health

# fastapi
ENV=local
APP_VERSION=v1.0.0
SECRET_KEY=change-me-local-secret
COOKIE_DOMAIN=localhost
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=true

# ai-worker
AI_WORKER_VERSION=v1.0.0

# db
DB_HOST=localhost
DB_PORT=3306
DB_EXPOSE_PORT=3306
DB_USER=all4health
DB_PASSWORD=password
DB_ROOT_PASSWORD=password
DB_NAME=ai_health
DB_CONNECT_TIMEOUT=5
DB_CONNECTION_POOL_MAXSIZE=10

# pytest DB override
# Use TEST_DB_* when pytest should connect with a different user/database.
TEST_DB_HOST=127.0.0.1
TEST_DB_PORT=3306
TEST_DB_USER=root
TEST_DB_PASSWORD=password
TEST_DB_NAME=test

# redis
# For host uvicorn run: redis://localhost:6379/0
# For docker compose app container: redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# jwt / auth
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_MINUTES=10080
JWT_LEEWAY=5
AUTH_RATE_LIMIT_MAX_FAILURES=5
AUTH_RATE_LIMIT_MAX_IP_FAILURES=30
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
EMAIL_VERIFICATION_EXPIRE_HOURS=24
EMAIL_VERIFICATION_COOLDOWN_SECONDS=60
PASSWORD_RESET_EXPIRE_MINUTES=30
PASSWORD_RESET_COOLDOWN_SECONDS=60

# openai llm
# Keep disabled until OPENAI_API_KEY is set locally.
ADVICE_LLM_ENABLED=false
REPORT_LLM_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=10
